
msgid "NOT RUNNING"
msgstr "未运行"

msgid "RUNNING"
msgstr "运行中"

msgid "Rtp2httpd"
msgstr "Rtp2httpd"

msgid "rtp2httpd converts RTP/UDP/RTSP media into http stream."
msgstr "rtp2httpd 用于将 RTP/UDP/RTSP 媒体流转换为 HTTP 流。"

msgid "Add instance"
msgstr "添加实例"

msgid "Enable"
msgstr "启用"

msgid "Auto restart after crash"
msgstr "程序崩溃后自动重启"

msgid "Port"
msgstr "端口"

msgid "Source interface"
msgstr "上游接口"

msgid "Default interface for all upstream traffic (multicast, FCC and RTSP)."
msgstr "所有上游流量（组播、FCC 和 RTSP）使用的默认接口。"

msgid "Respawn"
msgstr "自动重启"

msgid "Workers"
msgstr "工作进程数"

msgid "Number of worker processes. Set to 1 for resource-constrained devices, or CPU cores for best performance."
msgstr "工作进程数量。资源紧凑设备建议设置为 1，最佳吞吐量可以设置为 CPU 核心数。"

msgid "Use Config File"
msgstr "使用配置文件"

msgid "Use config file instead of individual options"
msgstr "使用配置文件而不是单独的选项"

msgid "Max clients allowed"
msgstr "最大客户端数"

msgid "Buffer Pool Max Size"
msgstr "缓冲池最大容量"

msgid "Maximum number of buffers in zero-copy pool. Default is 16384 (~24MB). Not recommended when running behind reverse proxies."
msgstr "零拷贝缓冲池的最大缓冲区数量。默认 16384（约24MB）。使用反向代理时不建议开启。"

msgid "External M3U URL"
msgstr "外部 M3U URL"

msgid "External M3U update interval"
msgstr "外部 M3U 更新间隔"

msgid "External M3U automatic update interval in seconds (default: 7200 = 2 hours). Set to 0 to disable automatic updates."
msgstr "外部 M3U 自动更新间隔（秒），默认 7200（2 小时）。设为 0 禁用自动更新。"

msgid "Logging level"
msgstr "日志级别"

msgid "Enable zero-copy"
msgstr "启用零拷贝发送"

msgid "Enable zero-copy send with MSG_ZEROCOPY for better performance. Requires kernel 4.14+. On supported devices, this can improve throughput and reduce CPU usage, especially under high concurrent load."
msgstr "启用 MSG_ZEROCOPY 零拷贝发送以提升性能。需要内核 4.14+。在支持的设备上，可提升吞吐量并降低 CPU 占用，特别是在高并发负载下。"

msgid "Status Dashboard"
msgstr "状态面板"

msgid "Open Status Dashboard"
msgstr "打开状态面板"

msgid "Player Page"
msgstr "播放器页面"

msgid "Open Player Page"
msgstr "打开播放器页面"

msgid "Multicast Rejoin Interval"
msgstr "组播周期性重新加入间隔"

msgid "Multicast rejoin interval in seconds (default 0, disabled). Set to a positive value (e.g., 60) to periodically rejoin multicast groups. Recommended value: 30-120 seconds (less than typical switch timeout of 260s). Only use when experiencing multicast stream interruptions."
msgstr "组播周期性重新加入间隔（秒）（默认值0，表示禁用）。将此值设置为一个正数（例如60），以定期重新加入多播组。建议值：30-120秒（需小于典型交换机的超时时间260秒）。仅在遇到组播流中断时启用此功能。"

msgid "FCC Listen Port Range"
msgstr "FCC 监听端口范围"

msgid "Local UDP port range for FCC client sockets (format: start-end, e.g., 40000-40100). Leave empty to use random ports."
msgstr "FCC 客户端套接字使用的本地 UDP 端口范围（格式：起始端口-结束端口，例如：40000-40100）。留空则使用随机端口。"

msgid "Fetch M3U playlist from a URL (file://, http://, https:// supported)"
msgstr "从URL获取M3U播放列表（支持file://、http://、https://协议）"

msgid "Log"
msgstr "日志"

msgid "View Log"
msgstr "查看日志"

msgid "Refresh"
msgstr "刷新"

msgid "Close"
msgstr "关闭"

msgid "Log Viewer"
msgstr "日志查看器"

msgid "Loading..."
msgstr "加载中..."

msgid "Failed to load log data. Please check if the service is running."
msgstr "日志数据加载失败。请检查服务是否正在运行。"

msgid "No rtp2httpd log entries found."
msgstr "未找到rtp2httpd日志。"

msgid "Collecting data..."
msgstr "正在收集数据..."

msgid "Direct editor for the configuration file located at /etc/rtp2httpd.conf."
msgstr "编辑位于 /etc/rtp2httpd.conf 的配置文件。"

msgid "Note: The configuration file does not currently exist. It will be created upon saving."
msgstr "注意：未发现配置文件。保存时将自动创建。"

msgid "This page displays the real-time log for rtp2httpd."
msgstr "显示 rtp2httpd 的实时日志。"

